# ============================================================
# .env.example — 복사 후 .env 로 사용하십시오 (cp .env.example .env)
# ⚠️ 실제 값(키/시크릿/계좌번호/토큰)은 절대 이 파일이나 Git에 넣지 마십시오.
#    .env 는 .gitignore 로 추적 제외됩니다.
# ============================================================

# ----- 실행 프로파일 -----
SPRING_PROFILES_ACTIVE=local

# ----- 거래 모드: BACKTEST | PAPER | SEMI_AUTO | AUTO -----
# 최초 기동은 반드시 PAPER 또는 BACKTEST 로 시작하십시오.
TRADING_MODE=PAPER

# ----- 전역 Kill Switch (true 면 모든 신규 주문 차단) -----
KILL_SWITCH_ENABLED=false

# ----- MySQL -----
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=trading
MYSQL_USER=app
MYSQL_PASSWORD=changeme_local_only

# ----- Redis -----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ----- 증권사 Open API 연동 -----
# 기본은 mock(시뮬레이션). 실 연동은 BROKER_PROVIDER=rest + 아래 값 채움.
# ⚠️ 상세 스펙/엔드포인트는 증권사 공식 문서 확인 후 채웁니다. 추측 금지.
#    (토스증권은 현재 개인 주문 Open API 미공개 — KIS/키움 등 공식 API 사용 시 동일 어댑터로 연동)
BROKER_PROVIDER=mock
BROKER_API_BASE_URL=
BROKER_TOKEN_URL=
BROKER_APP_KEY=__SET_IN_LOCAL_ENV_ONLY__
BROKER_APP_SECRET=__SET_IN_LOCAL_ENV_ONLY__
BROKER_ACCOUNT_NO=__SET_IN_LOCAL_ENV_ONLY__

# ----- AI 분석 제공자 (사용하는 경우) -----
AI_PROVIDER_BASE_URL=
AI_PROVIDER_API_KEY=__SET_IN_LOCAL_ENV_ONLY__
AI_MODEL_NAME=

# ----- 위험 한도 기본값 (RISK_POLICY.md 와 일치시킬 것) -----
RISK_MAX_POSITION_PCT=10          # 종목별 최대 투자 비중 (%)
RISK_MAX_SECTOR_PCT=30            # 섹터별 최대 투자 비중 (%)
RISK_MAX_ORDER_AMOUNT=1000000     # 1회 최대 주문 금액 (KRW)
RISK_MAX_DAILY_ORDER_AMOUNT=5000000  # 일일 최대 주문 금액 (KRW)
RISK_MAX_DAILY_LOSS=300000        # 일일 최대 손실 한도 (KRW)
RISK_MAX_LOSS_PCT=5               # 최대 허용 손실률 (%)
RISK_ORDER_RATE_PER_MIN=5         # 분당 최대 주문 건수
RISK_MIN_CONFIDENCE=0.6           # 최소 신뢰도 (이 미만 신호는 주문 후보 제외)

# ----- 관측/운영 -----
LOG_LEVEL=INFO
LOG_MASKING_ENABLED=true

# ----- 관리자 API 인증 (로컬 전용 더미) -----
ADMIN_API_TOKEN=__SET_IN_LOCAL_ENV_ONLY__
